      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="UPDATE dbo.stg_Movement_SDR SET CATEGORY_CODE = &#x27;SDR&#x27;;" />
      </DTS:ObjectData>
    </DTS:Executable>
