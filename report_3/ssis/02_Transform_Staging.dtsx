      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- ============================================================
-- Script 04: Transform and Clean Staging Data
-- DFF Data Warehouse Project — Report 3
-- Run in SSMS AFTER Package 1 (Extract) has loaded CSV data
-- into staging tables. These transformations prepare the data
-- for loading into the data mart.
-- ============================================================
USE [team1_staging_area];" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\T1_Update_CATEGORY_CODE_SDR"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{EED19675-CA9A-46E3-B2FF-537CB95C45CD}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="T1_Update_CATEGORY_CODE_SDR">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- ===============================
-- MOVEMENT TABLE TRANSFORMATIONS
-- ===============================

-- T1: Add CATEGORY_CODE column to each movement staging table
-- This column does not exist in the CSV files; it is derived 
-- from the filename (e.g., wsdr.csv → &#x27;SDR&#x27;)

ALTER TABLE dbo.stg_Movement_SDR ADD CATEGORY_CODE CHAR(3);" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\T1_Add_CATEGORY_CODE_CSO"
