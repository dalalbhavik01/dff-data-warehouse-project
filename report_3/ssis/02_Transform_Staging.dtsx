    <DTS:Executable
      DTS:refId="Package\T2:_Replace_NULL/blank_SALE_with_N_(No"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{2523966D-650B-4A81-96A7-DABF7FCA5CA5}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="T2:_Replace_NULL/blank_SALE_with_N_(No">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- T2: Replace NULL/blank SALE with &#x27;N&#x27; (No Promotion)
-- The SALE column is NULL for ~90% of rows; we normalize to &#x27;N&#x27;
-- so that promotion lookup joins work correctly.

UPDATE dbo.stg_Movement_SDR SET SALE = &#x27;N&#x27; WHERE SALE IS NULL OR LTRIM(RTRIM(SALE)) = &#x27;&#x27;;
UPDATE dbo.stg_Movement_CSO SET SALE = &#x27;N&#x27; WHERE SALE IS NULL OR LTRIM(RTRIM(SALE)) = &#x27;&#x27;;
UPDATE dbo.stg_Movement_TPA SET SALE = &#x27;N&#x27; WHERE SALE IS NULL OR LTRIM(RTRIM(SALE)) = &#x27;&#x27;;
UPDATE dbo.stg_Movement_CRA SET SALE = &#x27;N&#x27; WHERE SALE IS NULL OR LTRIM(RTRIM(SALE)) = &#x27;&#x27;;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Print_Step_11"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{BED1C939-5A3E-4912-AE3A-BE4BAAA748D6}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="Print_Step_11">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="PRINT &#x27;T2 Complete: NULL SALE values replaced with N.&#x27;;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Verification:_Check_SALE_distribution_af"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{6C530A63-0703-46B4-BF20-E786661C0BF6}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="Verification:_Check_SALE_distribution_af">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- Verification: Check SALE distribution after cleaning
SELECT &#x27;SDR&#x27; AS Category, SALE, COUNT(*) AS cnt FROM dbo.stg_Movement_SDR GROUP BY SALE
UNION ALL
SELECT &#x27;CSO&#x27;, SALE, COUNT(*) FROM dbo.stg_Movement_CSO GROUP BY SALE
UNION ALL
SELECT &#x27;TPA&#x27;, SALE, COUNT(*) FROM dbo.stg_Movement_TPA GROUP BY SALE
UNION ALL
SELECT &#x27;CRA&#x27;, SALE, COUNT(*) FROM dbo.stg_Movement_CRA GROUP BY SALE
ORDER BY 1, 2;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\==============================="
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{51A38FFF-1CAC-4EFB-99A7-2832BA75D4B6}"
