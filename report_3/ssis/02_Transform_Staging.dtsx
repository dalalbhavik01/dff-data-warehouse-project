    <DTS:Executable
      DTS:refId="Package\T4:_Clean_product_descriptions_—_strip_l"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{1BB0502C-CAFA-4F2A-AB0C-2E4E6A19A48B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="T4:_Clean_product_descriptions_—_strip_l">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- T4: Clean product descriptions — strip leading # and ~ characters
UPDATE dbo.stg_Product_SDR SET DESCRIP = LTRIM(REPLACE(REPLACE(DESCRIP, &#x27;#&#x27;, &#x27;&#x27;), &#x27;~&#x27;, &#x27;&#x27;));
UPDATE dbo.stg_Product_CSO SET DESCRIP = LTRIM(REPLACE(REPLACE(DESCRIP, &#x27;#&#x27;, &#x27;&#x27;), &#x27;~&#x27;, &#x27;&#x27;));
UPDATE dbo.stg_Product_TPA SET DESCRIP = LTRIM(REPLACE(REPLACE(DESCRIP, &#x27;#&#x27;, &#x27;&#x27;), &#x27;~&#x27;, &#x27;&#x27;));
UPDATE dbo.stg_Product_CRA SET DESCRIP = LTRIM(REPLACE(REPLACE(DESCRIP, &#x27;#&#x27;, &#x27;&#x27;), &#x27;~&#x27;, &#x27;&#x27;));" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Print_Step_23"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{1E05A482-D0E5-4803-A632-5EAB3CADDD93}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="Print_Step_23">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="PRINT &#x27;T4 Complete: Product descriptions cleaned.&#x27;;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\T5:_Create_unified_tmp_Product_All_table"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{CD40AE69-B230-4C2C-A48A-E8C92E3AA31C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="T5:_Create_unified_tmp_Product_All_table">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- T5: Create unified tmp_Product_All table (UNION of 4 category tables)
-- This temporary table is used to load DimProduct
IF OBJECT_ID(&#x27;dbo.tmp_Product_All&#x27;, &#x27;U&#x27;) IS NOT NULL
    DROP TABLE dbo.tmp_Product_All;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_Step_25"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{7E06A6C6-BCB0-4811-9696-1712C88472B5}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="SQL_Step_25">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="SELECT COM_CODE, UPC, DESCRIP, SIZE, CASE_PACK, NITEM, CATEGORY_CODE
INTO dbo.tmp_Product_All
FROM (
    SELECT COM_CODE, UPC, DESCRIP, SIZE, CASE_PACK, NITEM, CATEGORY_CODE FROM dbo.stg_Product_SDR
    UNION ALL
    SELECT COM_CODE, UPC, DESCRIP, SIZE, CASE_PACK, NITEM, CATEGORY_CODE FROM dbo.stg_Product_CSO
    UNION ALL
    SELECT COM_CODE, UPC, DESCRIP, SIZE, CASE_PACK, NITEM, CATEGORY_CODE FROM dbo.stg_Product_TPA
    UNION ALL
    SELECT COM_CODE, UPC, DESCRIP, SIZE, CASE_PACK, NITEM, CATEGORY_CODE FROM dbo.stg_Product_CRA
) AS all_products;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Print_Step_26"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{B2A9C719-5360-4C66-BDAE-266B7CE31818}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="Print_Step_26">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="PRINT &#x27;T5 Complete: tmp_Product_All created.&#x27;;
SELECT &#x27;tmp_Product_All&#x27; AS TableName, COUNT(*) AS RowCount FROM dbo.tmp_Product_All;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\==============================="
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{D65E262A-2824-455D-AEE3-2CD92A1DB3BB}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="===============================">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- ===============================
-- STORE (DEMOGRAPHICS) TRANSFORMATIONS
-- ===============================

-- T6: Remove the &#x27;.&#x27; placeholder row (first row of DEMO.csv)
-- The first row in DEMO.csv has STORE = &#x27;.&#x27; for all fields
DELETE FROM dbo.stg_Store WHERE STORE = &#x27;.&#x27; OR ISNUMERIC(STORE) = 0;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\T7:_Replace_NULL/blank_NAME_and_CITY_wit"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{51B56F2B-439F-423B-9E0C-AFF52653864D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="T7:_Replace_NULL/blank_NAME_and_CITY_wit">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- T7: Replace NULL/blank NAME and CITY with &#x27;UNKNOWN&#x27;
UPDATE dbo.stg_Store SET NAME = &#x27;UNKNOWN&#x27; WHERE NAME IS NULL OR LTRIM(RTRIM(NAME)) = &#x27;&#x27;;
UPDATE dbo.stg_Store SET CITY = &#x27;UNKNOWN&#x27; WHERE CITY IS NULL OR LTRIM(RTRIM(CITY)) = &#x27;&#x27;;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Print_Step_29"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{3CAEE87D-224E-4275-B273-8D9ABF3AA56D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="Print_Step_29">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="PRINT &#x27;T6-T7 Complete: Store data cleaned.&#x27;;
SELECT COUNT(*) AS StoreCount FROM dbo.stg_Store;" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\==============================="
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{1208DD23-3653-434C-996A-2262BB2F9003}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="===============================">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="OLE_Staging"
          SQLTask:SqlStatementSource="-- ===============================
-- FINAL VERIFICATION
-- ===============================
PRINT &#x27;========================================&#x27;;
PRINT &#x27;  STAGING TRANSFORMATION COMPLETE&#x27;;
PRINT &#x27;========================================&#x27;;

SELECT &#x27;stg_Movement_SDR&#x27; AS TableName, COUNT(*) AS RowCount FROM dbo.stg_Movement_SDR
UNION ALL SELECT &#x27;stg_Movement_CSO&#x27;, COUNT(*) FROM dbo.stg_Movement_CSO
UNION ALL SELECT &#x27;stg_Movement_TPA&#x27;, COUNT(*) FROM dbo.stg_Movement_TPA
UNION ALL SELECT &#x27;stg_Movement_CRA&#x27;, COUNT(*) FROM dbo.stg_Movement_CRA
UNION ALL SELECT &#x27;stg_Product_SDR&#x27;,  COUNT(*) FROM dbo.stg_Product_SDR
UNION ALL SELECT &#x27;stg_Product_CSO&#x27;,  COUNT(*) FROM dbo.stg_Product_CSO
UNION ALL SELECT &#x27;stg_Product_TPA&#x27;,  COUNT(*) FROM dbo.stg_Product_TPA
UNION ALL SELECT &#x27;stg_Product_CRA&#x27;,  COUNT(*) FROM dbo.stg_Product_CRA
UNION ALL SELECT &#x27;stg_Store&#x27;,        COUNT(*) FROM dbo.stg_Store
UNION ALL SELECT &#x27;tmp_Product_All&#x27;,  COUNT(*) FROM dbo.tmp_Product_All
ORDER BY TableName;" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
